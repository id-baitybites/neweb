generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  domain      String?     @unique
  logoUrl     String?
  faviconUrl  String?
  plan        TenantPlan  @default(FREE)
  isActive    Boolean     @default(true)
  theme       Json        @default("{\"font\": \"Inter\", \"accent\": \"#FFB6C1\", \"primary\": \"#FF69B4\", \"secondary\": \"#8B4513\", \"background\": \"#FFF5F7\"}")
  config      Json        @default("{\"currency\": \"IDR\", \"language\": \"id\", \"timezone\": \"Asia/Jakarta\", \"deliveryFee\": 25000, \"minPreOrderDays\": 1}")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  inventory   Inventory[]
  orders      Order[]
  products    Product[]
  testimonies Testimony[]
  users       User[]
}

model User {
  id          String      @id @default(cuid())
  tenantId    String?                     // null = SUPER_ADMIN (platform-level)
  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
  email       String
  password    String
  name        String?
  image       String?                     // Profile picture URL
  role        Role        @default(CUSTOMER)
  orders      Order[]
  testimonies Testimony[]
  profile     CustomerProfile?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([tenantId, email])           // email unique per tenant
}

// ─── CustomerProfile ──────────────────────────────────────────────────────────
// Extended info for customer accounts (delivery, contact, etc.)

model CustomerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  phone         String?
  dateOfBirth   DateTime?
  gender        String?
  // Default delivery address
  addressLine   String?
  city          String?
  province      String?
  postalCode    String?
  notes         String?  // Allergy / special notes for orders
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  price       Float
  description String
  stock       Int         @default(0)
  imageUrl    String?
  category    String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
}

model Order {
  id            String         @id @default(cuid())
  tenantId      String
  userId        String?
  status        OrderStatus    @default(PENDING)
  total         Float
  paymentStatus String         @default("UNPAID")
  paymentToken  String?
  method        DeliveryMethod @default(DELIVERY)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  customerDate  String?
  customerEmail String?
  customerName  String?
  customerPhone String?
  delivery      Delivery?
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  user          User?          @relation(fields: [userId], references: [id])
  orderItems    OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  custom    Json?
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Inventory {
  id            String   @id @default(cuid())
  tenantId      String
  material      String
  quantity      Float
  unit          String
  lowStockAlert Float    @default(10)
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, material])
}

model Delivery {
  id             String  @id @default(cuid())
  orderId        String  @unique
  address        String
  method         String
  status         String  @default("PENDING")
  trackingNumber String?
  qrCode         String?
  order          Order   @relation(fields: [orderId], references: [id])
}

model Testimony {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  content     String
  rating      Int      @default(5)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

enum Role {
  SUPER_ADMIN
  OWNER
  STAFF
  CUSTOMER
}

enum TenantPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum OrderStatus {
  PENDING
  PROCESSING
  READY
  SHIPPED
  COMPLETED
  CANCELLED
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}
